# ===== HomeDome Content Engine =====
# Copy this to .env and fill in your values

# --- Google AI (Gemini) ---
GOOGLE_API_KEY=your_google_ai_api_key_here

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=TX3LPaxmHKxFdv7VOQHJ  # Liam - Energetic, Social Media Creator voice

# --- Google Drive ---
GOOGLE_DRIVE_FOLDER_ID=1xtwCAFNT5iSKQ9v_cBC_OA1KeUktfq5v
# Path to service account JSON or OAuth credentials
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json

# --- YouTube (OAuth2) ---
YOUTUBE_CLIENT_SECRET_PATH=credentials/youtube_client_secret.json
YOUTUBE_TOKEN_PATH=credentials/youtube_token.json

# --- TikTok ---
# TikTok Content Posting API (requires approved app)
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# --- Content Settings ---
BRAND_NAME=HomeDome
BRAND_DOMAIN=homedome.com.ua
LANGUAGE=uk  # Ukrainian
CONTENT_NICHE=energy_solutions  # ups, solar, ess
