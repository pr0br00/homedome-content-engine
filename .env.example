# ===== HomeDome Content Engine =====
# Copy this to .env and fill in your values

# --- Google AI (Gemini) ---
GOOGLE_API_KEY=your_google_ai_api_key_here

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=TX3LPaxmHKxFdv7VOQHJ  # Liam - Energetic, Social Media Creator

# --- Post-Bridge (Social Media Publishing) ---
# Get your API key: https://www.post-bridge.com → Settings → API Keys
# API docs: https://api.post-bridge.com/reference
# $5/month add-on to your Post-Bridge plan
POST_BRIDGE_API_KEY=pb_live_your_key_here

# --- Content Settings ---
BRAND_NAME=HomeDome
BRAND_DOMAIN=homedome.com.ua
LANGUAGE=uk  # Ukrainian
CONTENT_NICHE=energy_solutions  # ups, solar, ess
